# AI Intelligence Hub — Environment Variables
# Copy this file to .env.local and fill in your values

# ── Cron ─────────────────────────────────────────────────────────────
# Secret pour protéger le endpoint /api/cron
CRON_SECRET=your-cron-secret-here

# ── Base de données — choisir UNE des options ci-dessous ─────────────

# Option A : Postgres / Neon (recommandé)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Option B : Supabase
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── APIs optionnelles ─────────────────────────────────────────────────
# HuggingFace (pour les papers et modèles privés)
# HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Notes d'installation ──────────────────────────────────────────────
# 1. Copier ce fichier : cp .env.local.example .env.local
# 2. Remplir DATABASE_URL ou SUPABASE_*
# 3. Exécuter lib/schema.sql sur la base
# 4. Relancer : npm run dev
# 5. Appeler POST /api/cron avec Authorization: Bearer <CRON_SECRET>
